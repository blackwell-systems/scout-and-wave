rent="1" source="29" style="edgeStyle=orthogonalEdgeStyle;fontSize=18;" target="31"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=18;" value="Human review&#10;interface freeze checkpoint" vertex="1"><mxGeometry height="64" width="370" x="605" y="1474" as="geometry"/></mxCell><mxCell id="34" edge="1" parent="1" source="31" style="edgeStyle=orthogonalEdgeStyle;fontSize=18;" target="33"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="35" edge="1" parent="1" source="33" style="edgeStyle=orthogonalEdgeStyle;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=18;" target="31" value="revise contracts"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1090" y="1506"/><mxPoint x="1090" y="1349"/></Array></mxGeometry></mxCell><mxCell id="36" edge="1" parent="1" source="33" style="edgeStyle=orthogonalEdgeStyle;fontSize=18;" target="39" value="approved"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="37" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=18;" value="IMPL doc finalized · done" vertex="1"><mxGeometry height="64" width="250" x="665" y="3550" as="geometry"/></mxCell><mxCell id="38" edge="1" parent="1" source="20" style="edgeStyle=orthogonalEdgeStyle;fontSize=20;" target="37" value="no"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="39" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=18;" value="Scaffold files&#10;needed?" vertex="1"><mxGeometry height="110" width="230" x="675" y="1598" as="geometry"/></mxCell><mxCell id="40" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Scaffold Agent&lt;/b&gt;&lt;br&gt;• create scaffold source files (types only)&l