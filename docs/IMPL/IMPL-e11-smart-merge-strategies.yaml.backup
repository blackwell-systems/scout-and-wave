interface_contracts:
  - name: AnalyzeDiffPattern
    description: |
      Analyzes git diff for a single file to classify the change pattern: append-only
      (new functions/tests), line edits (modifying existing lines), or deletions.
      Returns pattern enum and hunk metadata for merge decision.
    definition: |
      // DiffPattern classifies the type of changes in a git diff
      type DiffPattern string

      const (
          DiffPatternAppendOnly DiffPattern = "append_only"  // New lines only, no edits
          DiffPatternLineEdits  DiffPattern = "line_edits"   // Modifies existing lines
          DiffPatternDeletions  DiffPattern = "deletions"    // Removes lines
          DiffPatternMixed      DiffPattern = "mixed"        // Combination of above
      )

      // DiffAnalysis holds the result of analyzing a single agent's diff for one file
      type DiffAnalysis struct {
          AgentID string
          File    string
          Pattern DiffPattern
          Hunks   []HunkRange
          Hash    string  // SHA256 of final file content
      }

      // AnalyzeDiffPattern inspects the diff between baseRef and agentBranch for file
      // and returns the pattern classification. Uses git diff --unified=0 to get hunks.
      func AnalyzeDiffPattern(repoPath, baseRef, agentBranch, file string) (*DiffAnalysis, error)
    location: pkg/protocol/conflict_predict.go
    integration_required: true
    suggested_callers:
      - pkg/engine/finalize_steps.go

  - name: ConflictPredictionWithStrategy
    description: |
      Enhanced E11 conflict prediction that not only detects overlapping files but
      analyzes diff patterns and suggests merge strategies. Returns recommendations
      for auto-merge (append-only), manual merge (line edits), or hybrid approaches.
    definition: |
      // MergeStrategy suggests how to resolve a detected conflict
      type MergeStrategy string

      const (
          MergeStrategyAutomatic MergeStrategy = "automatic"  // Safe to auto-merge
          MergeStrategyManual    MergeStrategy = "manual"     // Requires human review
          MergeStrategySequential MergeStrategy = "sequential" // Merge agents in order
      )

      // ConflictPredictionEnhanced extends ConflictPrediction with strategy metadata
      type ConflictPredictionEnhanced struct {
          File              string
          Agents            []string
          Strategy          MergeStrategy
          Reason            string  // Human-readable explanation
          MergeOrder        []string // Suggested agent merge order (for sequential)
          DiffAnalyses      []*DiffAnalysis
      }

      // ConflictDataEnhanced extends ConflictData with strategy recommendations
      type ConflictDataEnhanced struct {
          ConflictsDetected int
          Conflicts         []ConflictPredictionEnhanced
          AutoMergeable     int  // Count of conflicts safe to auto-merge
      }

      // PredictConflictsWithStrategy is the enhanced E11 function that analyzes patterns
      func PredictConflictsWithStrategy(ctx context.Context, manifest *IMPLManifest, waveNum int) result.Result[ConflictDataEnhanced]
    location: pkg/protocol/conflict_predict.go

  - name: DiffStatistics
    description: |
      Git primitive to extract diff statistics: lines added, removed, files changed.
      Used to determine if a diff is append-only (additions > 0, removals == 0).
    definition: |
      // DiffStats holds statistics for a git diff
      type DiffStats struct {
          FilesChanged  int
          LinesAdded    int
          LinesRemoved  int
      }

      // GetDiffStats runs git diff --numstat between fromRef and toRef for file
      // and returns parsed statistics. Returns zero stats on error (safe default).
      func GetDiffStats(repoPath, fromRef, toRef, file string) (*DiffStats, error)
    location: internal/git/commands.go

  - name: StepPredictConflictsEnhanced
    description: |
      Replacement for StepPredictConflicts that calls PredictConflictsWithStrategy
      and logs the recommendations. If all conflicts are auto-mergeable, proceeds
      to auto-merge instead of blocking. Otherwise, surfaces strategy suggestions
      in the error message.
    definition: |
      // StepPredictConflictsEnhanced replaces StepPredictConflicts with pattern analysis.
      // Returns fatal error only when conflicts require manual intervention.
      // Auto-mergeable conflicts proceed to StepAutoMergeAppendConflicts.
      func StepPredictConflictsEnhanced(ctx context.Context, opts FinalizeWaveOpts, manifest *protocol.IMPLManifest, onEvent EventCallback) (*StepResult, *protocol.ConflictDataEnhanced, error)
    location: pkg/engine/finalize_steps.go

  - name: StepAutoMergeAppendConflicts
    description: |
      New finalize step that auto-merges agents with append-only conflicts.
      Runs after StepPredictConflictsEnhanced detects append patterns.
      Merges agents in file-sorted order, verifies no git conflicts after merge,
      falls back to manual on unexpected merge failure.
    definition: |
      // AutoMergeData holds the result of automatic merge for append-only conflicts
      type AutoMergeData struct {
          File           string
          Agents         []string
          MergeOrder     []string
          MergesApplied  int
          FallbackNeeded bool
          Reason         string
      }

      // StepAutoMergeAppendConflicts attempts automatic merge for append-only conflicts.
      // Returns fatal error if merge produces conflicts (fallback to manual).
      func StepAutoMergeAppendConflicts(ctx context.Context, opts FinalizeWaveOpts, conflicts []protocol.ConflictPredictionEnhanced, onEvent EventCallback) (*StepResult, []AutoMergeData, error)
    location: pkg/engine/finalize_steps.go

waves:
  - number: 1
    agents:
      - id: A
        task: |
          ## Agent A — conflict_predict.go: Pattern Analysis

          Enhance `pkg/protocol/conflict_predict.go` with diff pattern classification.

          ### 1. Add DiffPattern types and DiffAnalysis struct

          After line 24 (ConflictPrediction struct), add the new types from the
          interface contracts:

          ```go
          // DiffPattern classifies the type of changes in a git diff
          type DiffPattern string

          const (
              DiffPatternAppendOnly DiffPattern = "append_only"
              DiffPatternLineEdits  DiffPattern = "line_edits"
              DiffPatternDeletions  DiffPattern = "deletions"
              DiffPatternMixed      DiffPattern = "mixed"
          )

          // DiffAnalysis holds the result of analyzing a single agent's diff for one file
          type DiffAnalysis struct {
              AgentID string
              File    string
              Pattern DiffPattern
              Hunks   []HunkRange
              Hash    string
          }

          // MergeStrategy suggests how to resolve a detected conflict
          type MergeStrategy string

          const (
              MergeStrategyAutomatic  MergeStrategy = "automatic"
              MergeStrategyManual     MergeStrategy = "manual"
              MergeStrategySequential MergeStrategy = "sequential"
          )

          // ConflictPredictionEnhanced extends ConflictPrediction with strategy metadata
          type ConflictPredictionEnhanced struct {
              File         string
              Agents       []string
              Strategy     MergeStrategy
              Reason       string
              MergeOrder   []string
              DiffAnalyses []*DiffAnalysis
          }

          // ConflictDataEnhanced extends ConflictData with strategy recommendations
          type ConflictDataEnhanced struct {
              ConflictsDetected int
              Conflicts         []ConflictPredictionEnhanced
              AutoMergeable     int
          }
          ```

          ### 2. Implement AnalyzeDiffPattern function

          Before `PredictConflictsFromReports` (around line 35), add:

          ```go
          // AnalyzeDiffPattern inspects the diff between baseRef and agentBranch for file
          // and returns the pattern classification.
          func AnalyzeDiffPattern(repoPath, baseRef, agentBranch, file string) (*DiffAnalysis, error) {
              if repoPath == "" {
                  return nil, fmt.Errorf("repoPath required")
              }

              // Get diff with zero context to extract hunks
              diff, err := git.DiffUnifiedZero(repoPath, baseRef, agentBranch, file)
              if err != nil {
                  return nil, fmt.Errorf("git diff failed: %w", err)
              }

              hunks := parseDiffHunks(diff)

              // Get diff stats to determine pattern
              stats, err := git.GetDiffStats(repoPath, baseRef, agentBranch, file)
              if err != nil {
                  // Fallback to conservative pattern on stats error
                  return &DiffAnalysis{
                      File:    file,
                      Pattern: DiffPatternMixed,
                      Hunks:   hunks,
                  }, nil
              }

              // Classify pattern based on stats
              pattern := DiffPatternMixed
              if stats.LinesRemoved == 0 && stats.LinesAdded > 0 {
                  // Pure additions → append-only
                  pattern = DiffPatternAppendOnly
              } else if stats.LinesRemoved > 0 && stats.LinesAdded == 0 {
                  pattern = DiffPatternDeletions
              } else if stats.LinesRemoved > 0 && stats.LinesAdded > 0 {
                  pattern = DiffPatternLineEdits
              }

              // Get file hash from agent branch
              hash, err := computeFileHashInBranch(repoPath, agentBranch, file)
              if err != nil {
                  hash = "" // Non-fatal, leave empty
              }

              return &DiffAnalysis{
                  File:    file,
                  Pattern: pattern,
                  Hunks:   hunks,
                  Hash:    hash,
              }, nil
          }
          ```

          ### 3. Implement PredictConflictsWithStrategy

          After `PredictConflictsFromReports` (around line 125), add the enhanced function:

          ```go
          // PredictConflictsWithStrategy extends E11 with diff pattern analysis and merge strategies.
          func PredictConflictsWithStrategy(ctx context.Context, manifest *IMPLManifest, waveNum int) result.Result[ConflictDataEnhanced] {
              _ = ctx
              if manifest == nil {
                  return result.NewSuccess(ConflictDataEnhanced{})
              }

              // Find the target wave
              var targetWave *Wave
              for i := range manifest.Waves {
                  if manifest.Waves[i].Number == waveNum {
                      targetWave = &manifest.Waves[i]
                      break
                  }
              }
              if targetWave == nil {
                  return result.NewSuccess(ConflictDataEnhanced{})
              }

              // Build file->agents map (reuse existing logic from PredictConflictsFromReports)
              fileAgents := make(map[string][]string)
              for _, agent := range targetWave.Agents {
                  report, ok := manifest.CompletionReports[agent.ID]
                  if !ok {
                      continue
                  }
                  seen := make(map[string]bool)
                  allFiles := append([]string{}, report.FilesChanged...)
                  allFiles = append(allFiles, report.FilesCreated...)
                  for _, f := range allFiles {
                      if f == "" || isIMPLStateFile(f) {
                          continue
                      }
                      if !seen[f] {
                          seen[f] = true
                          fileAgents[f] = append(fileAgents[f], agent.ID)
                      }
                  }
              }

              // Analyze conflicts with pattern detection
              var enhancedPredictions []ConflictPredictionEnhanced
              autoMergeableCount := 0

              for file, agents := range fileAgents {
                  if len(agents) <= 1 {
                      continue
                  }

                  // Skip if identical content (existing E11 logic)
                  if manifest.FeatureSlug != "" && allAgentsHaveSameContent(manifest, file, agents, waveNum) {
                      continue
                  }

                  // Analyze diff pattern for each agent
                  var analyses []*DiffAnalysis
                  mergeBase, err := git.MergeBase(manifest.Repository,
                      fmt.Sprintf("saw/%s/wave%d-agent-%s", manifest.FeatureSlug, waveNum, agents[0]),
                      fmt.Sprintf("saw/%s/wave%d-agent-%s", manifest.FeatureSlug, waveNum, agents[1]))
                  if err != nil {
                      // Can't determine base — conservative default
                      enhancedPredictions = append(enhancedPredictions, ConflictPredictionEnhanced{
                          File:     file,
                          Agents:   agents,
                          Strategy: MergeStrategyManual,
                          Reason:   "Cannot determine merge base — manual merge required",
                      })
                      continue
                  }

                  allAppendOnly := true
                  for _, agentID := range agents {
                      branchName := fmt.Sprintf("saw/%s/wave%d-agent-%s", manifest.FeatureSlug, waveNum, agentID)
                      analysis, err := AnalyzeDiffPattern(manifest.Repository, mergeBase, branchName, file)
                      if err != nil {
                          allAppendOnly = false
                          continue
                      }
                      analysis.AgentID = agentID
                      analyses = append(analyses, analysis)
                      if analysis.Pattern != DiffPatternAppendOnly {
                          allAppendOnly = false
                      }
                  }

                  // Determine strategy based on patterns
                  var strategy MergeStrategy
                  var reason string
                  if allAppendOnly && len(analyses) == len(agents) {
                      strategy = MergeStrategyAutomatic
                      reason = fmt.Sprintf("All %d agents have append-only changes (new functions/tests) — safe to auto-merge", len(agents))
                      autoMergeableCount++
                  } else if !agentsHaveOverlappingHunks(manifest, file, agents, waveNum) {
                      strategy = MergeStrategyAutomatic
                      reason = "Non-overlapping line ranges — git 3-way merge will succeed"
                      autoMergeableCount++
                  } else {
                      strategy = MergeStrategyManual
                      reason = "Overlapping line edits detected — manual merge required"
                  }

                  enhancedPredictions = append(enhancedPredictions, ConflictPredictionEnhanced{
                      File:         file,
                      Agents:       agents,
                      Strategy:     strategy,
                      Reason:       reason,
                      MergeOrder:   agents, // Default: alphabetical
                      DiffAnalyses: analyses,
                  })
              }

              data := ConflictDataEnhanced{
                  ConflictsDetected: len(enhancedPredictions),
                  Conflicts:         enhancedPredictions,
                  AutoMergeable:     autoMergeableCount,
              }

              if len(enhancedPredictions) == 0 {
                  return result.NewSuccess(data)
              }

              // Build warnings with strategy recommendations
              var warnings []result.SAWError
              for _, cp := range enhancedPredictions {
                  msg := fmt.Sprintf("E11 conflict prediction: %s modified by agents %v — Strategy: %s (%s)",
                      cp.File, cp.Agents, cp.Strategy, cp.Reason)
                  warnings = append(warnings, result.NewWarning("CONFLICT_PREDICT_WITH_STRATEGY", msg))
              }

              // Add summary
              summaryMsg := fmt.Sprintf("E11 conflict prediction: %d file(s) appear in multiple agent reports. %d auto-mergeable, %d require manual merge.",
                  len(enhancedPredictions), autoMergeableCount, len(enhancedPredictions)-autoMergeableCount)
              warnings = append([]result.SAWError{result.NewWarning("CONFLICT_PREDICT_WITH_STRATEGY", summaryMsg)}, warnings...)

              return result.NewPartial(data, warnings)
          }
          ```

          ### 4. Tests

          Add tests in `conflict_predict_test.go`:
          - `TestAnalyzeDiffPattern_AppendOnly` — verify append-only detection
          - `TestAnalyzeDiffPattern_LineEdits` — verify edit detection
          - `TestPredictConflictsWithStrategy_AutoMergeable` — verify auto-merge recommendation
          - `TestPredictConflictsWithStrategy_ManualRequired` — verify manual merge detection

          ### Verification Gate

          ```bash
          cd /Users/dayna.blackwell/code/scout-and-wave-go && \
            go test ./pkg/protocol -run TestAnalyzeDiffPattern -v && \
            go test ./pkg/protocol -run TestPredictConflictsWithStrategy -v
          ```

          ### Constraints

          - Do not modify existing `PredictConflictsFromReports` — it must remain unchanged for backward compatibility
          - New function `PredictConflictsWithStrategy` is the enhanced alternative
          - All new types are exported (capitalized) for use by finalize_steps.go
          - Use existing `git.DiffUnifiedZero` and `git.MergeBase` functions (no modifications)
          - Pattern detection must be conservative: when in doubt, classify as Manual

        files:
          - pkg/protocol/conflict_predict.go
          - pkg/protocol/conflict_predict_test.go

      - id: C
        task: |
          ## Agent C — commands.go: Git Diff Statistics Primitive

          Add `GetDiffStats` function to `internal/git/commands.go` for diff statistics.

          ### 1. Add DiffStats struct

          After the imports section (around line 14), add:

          ```go
          // DiffStats holds statistics for a git diff
          type DiffStats struct {
              FilesChanged  int
              LinesAdded    int
              LinesRemoved  int
          }
          ```

          ### 2. Implement GetDiffStats function

          At the end of the file (after existing functions), add:

          ```go
          // GetDiffStats runs git diff --numstat between fromRef and toRef for file
          // and returns parsed statistics. Returns zero stats on error (safe default).
          func GetDiffStats(repoPath, fromRef, toRef, file string) (*DiffStats, error) {
              if repoPath == "" || file == "" {
                  return &DiffStats{}, fmt.Errorf("repoPath and file required")
              }

              // git diff --numstat shows: <added>\t<removed>\t<file>
              out, err := RunOutput(repoPath, "diff", "--numstat", fromRef, toRef, "--", file)
              if err != nil {
                  return &DiffStats{}, fmt.Errorf("git diff --numstat failed: %w", err)
              }

              lines := strings.Split(strings.TrimSpace(out), "\n")
              if len(lines) == 0 || lines[0] == "" {
                  // No diff output — file unchanged
                  return &DiffStats{FilesChanged: 0}, nil
              }

              // Parse first line: "5\t2\tpkg/protocol/conflict_predict.go"
              fields := strings.Fields(lines[0])
              if len(fields) < 3 {
                  return &DiffStats{}, fmt.Errorf("unexpected numstat format: %s", lines[0])
              }

              added, err := strconv.Atoi(fields[0])
              if err != nil {
                  return &DiffStats{}, fmt.Errorf("failed to parse added lines: %w", err)
              }

              removed, err := strconv.Atoi(fields[1])
              if err != nil {
                  return &DiffStats{}, fmt.Errorf("failed to parse removed lines: %w", err)
              }

              return &DiffStats{
                  FilesChanged:  1,
                  LinesAdded:    added,
                  LinesRemoved:  removed,
              }, nil
          }
          ```

          ### 3. Tests

          Add to `commands_test.go`:

          ```go
          func TestGetDiffStats_AppendOnly(t *testing.T) {
              // Create temp repo with two commits: base, then append
              // Verify LinesAdded > 0, LinesRemoved == 0
          }

          func TestGetDiffStats_LineEdits(t *testing.T) {
              // Create temp repo with base commit, then modify existing lines
              // Verify both LinesAdded > 0 and LinesRemoved > 0
          }

          func TestGetDiffStats_NoChanges(t *testing.T) {
              // Same file in both refs — verify FilesChanged == 0
          }
          ```

          ### Verification Gate

          ```bash
          cd /Users/dayna.blackwell/code/scout-and-wave-go && \
            go test ./internal/git -run TestGetDiffStats -v
          ```

          ### Constraints

          - Use existing `RunOutput` helper (line 33) for git command execution
          - Handle empty diff output gracefully (returns zero stats, not error)
          - Parse `--numstat` format exactly: `<added>\t<removed>\t<file>`
          - Binary files show `-` for stats — treat as error (not supported)

        files:
          - internal/git/commands.go
          - internal/git/commands_test.go

  - number: 2
    agents:
      - id: B
        task: |
          ## Agent B — finalize_steps.go: Auto-Merge Orchestration

          Enhance `pkg/engine/finalize_steps.go` with auto-merge capability for append-only conflicts.

          ### 1. Add StepPredictConflictsEnhanced function

          Replace the existing `StepPredictConflicts` call site in `finalize.go` (line 344)
          with a new enhanced version. First, add the new step function to `finalize_steps.go`:

          ```go
          // StepPredictConflictsEnhanced calls protocol.PredictConflictsWithStrategy to detect
          // file-level conflicts with pattern analysis (E11 enhanced). If all conflicts are
          // auto-mergeable, proceeds to auto-merge. Otherwise, surfaces strategy suggestions.
          func StepPredictConflictsEnhanced(ctx context.Context, opts FinalizeWaveOpts, manifest *protocol.IMPLManifest, onEvent EventCallback) (*StepResult, *protocol.ConflictDataEnhanced, error) {
              const stepName = "predict-conflicts-enhanced"
              emitStepEvent(onEvent, stepName, "running", "")

              conflictRes := protocol.PredictConflictsWithStrategy(ctx, manifest, opts.WaveNum)
              if conflictRes.IsFatal() {
                  msg := ""
                  if len(conflictRes.Errors) > 0 {
                      msg = conflictRes.Errors[0].Message
                  }
                  emitStepEvent(onEvent, stepName, "failed", msg)
                  return &StepResult{
                      Step:   stepName,
                      Status: "failed",
                      Detail: msg,
                  }, nil, fmt.Errorf("predict-conflicts-enhanced: %s", msg)
              }

              data := conflictRes.GetData()

              // If no conflicts, success
              if data.ConflictsDetected == 0 {
                  emitStepEvent(onEvent, stepName, "complete", "no conflicts")
                  return &StepResult{
                      Step:   stepName,
                      Status: "success",
                      Detail: "no conflicts detected",
                  }, &data, nil
              }

              // If all conflicts are auto-mergeable, log recommendation and succeed
              if data.AutoMergeable == data.ConflictsDetected {
                  detail := fmt.Sprintf("%d conflict(s) detected, all auto-mergeable", data.AutoMergeable)
                  emitStepEvent(onEvent, stepName, "complete", detail)
                  loggerFrom(opts.Logger).Info("E11 enhanced: all conflicts are append-only patterns, will auto-merge")
                  return &StepResult{
                      Step:   stepName,
                      Status: "success",
                      Detail: detail,
                      Data:   data,
                  }, &data, nil
              }

              // Some conflicts require manual intervention
              var manualFiles []string
              for _, cp := range data.Conflicts {
                  if cp.Strategy == protocol.MergeStrategyManual {
                      manualFiles = append(manualFiles, cp.File)
                  }
              }

              msg := fmt.Sprintf("E11 conflict prediction: %d file(s) require manual merge: %v. See conflict strategy recommendations in warnings.",
                  len(manualFiles), manualFiles)
              emitStepEvent(onEvent, stepName, "failed", msg)
              return &StepResult{
                  Step:   stepName,
                  Status: "failed",
                  Detail: msg,
                  Data:   data,
              }, &data, fmt.Errorf("predict-conflicts-enhanced: %s", msg)
          }
          ```

          ### 2. Add StepAutoMergeAppendConflicts function

          After `StepPredictConflictsEnhanced`, add:

          ```go
          // AutoMergeData holds the result of automatic merge for append-only conflicts
          type AutoMergeData struct {
              File           string
              Agents         []string
              MergeOrder     []string
              MergesApplied  int
              FallbackNeeded bool
              Reason         string
          }

          // StepAutoMergeAppendConflicts attempts automatic merge for append-only conflicts.
          // Only called when StepPredictConflictsEnhanced returns auto-mergeable conflicts.
          func StepAutoMergeAppendConflicts(ctx context.Context, opts FinalizeWaveOpts, conflicts []protocol.ConflictPredictionEnhanced, onEvent EventCallback) (*StepResult, []AutoMergeData, error) {
              const stepName = "auto-merge-append-conflicts"
              emitStepEvent(onEvent, stepName, "running", "")

              manifest, err := protocol.Load(ctx, opts.IMPLPath)
              if err != nil {
                  return &StepResult{Step: stepName, Status: "failed"}, nil, fmt.Errorf("load manifest: %w", err)
              }

              var results []AutoMergeData
              for _, cp := range conflicts {
                  if cp.Strategy != protocol.MergeStrategyAutomatic {
                      continue
                  }

                  emitStepEvent(onEvent, stepName, "running", fmt.Sprintf("auto-merging %s", cp.File))

                  // Merge agents in order (alphabetical by default)
                  mergeOrder := cp.MergeOrder
                  mergesApplied := 0
                  for _, agentID := range mergeOrder {
                      branchName := protocol.BranchName(manifest.FeatureSlug, opts.WaveNum, agentID)
                      _, err := git.Run(opts.RepoPath, "merge", "--no-ff", branchName, "-m",
                          fmt.Sprintf("Auto-merge wave %d agent %s (append-only pattern)", opts.WaveNum, agentID))
                      if err != nil {
                          // Merge failed — check if it's a conflict
                          conflicted, _ := git.ConflictedFiles(opts.RepoPath)
                          if len(conflicted) > 0 {
                              // Unexpected conflict — abort and fall back to manual
                              _ = git.Run(opts.RepoPath, "merge", "--abort")
                              results = append(results, AutoMergeData{
                                  File:           cp.File,
                                  Agents:         cp.Agents,
                                  MergeOrder:     mergeOrder,
                                  MergesApplied:  mergesApplied,
                                  FallbackNeeded: true,
                                  Reason:         fmt.Sprintf("git merge produced conflicts despite append-only pattern: %v", conflicted),
                              })
                              return &StepResult{Step: stepName, Status: "failed", Detail: "auto-merge produced conflicts"},
                                  results, fmt.Errorf("auto-merge failed: %s", err)
                          }
                          // Non-conflict error (e.g., network, disk) — also abort
                          return &StepResult{Step: stepName, Status: "failed"}, results, fmt.Errorf("git merge error: %w", err)
                      }
                      mergesApplied++
                  }

                  results = append(results, AutoMergeData{
                      File:          cp.File,
                      Agents:        cp.Agents,
                      MergeOrder:    mergeOrder,
                      MergesApplied: mergesApplied,
                      Reason:        "Append-only pattern auto-merge succeeded",
                  })
              }

              detail := fmt.Sprintf("%d file(s) auto-merged", len(results))
              emitStepEvent(onEvent, stepName, "complete", detail)
              return &StepResult{
                  Step:   stepName,
                  Status: "success",
                  Detail: detail,
                  Data:   results,
              }, results, nil
          }
          ```

          ### 3. Wire into finalize.go

          In `pkg/engine/finalize.go` at line 344 (inside the `!isSolo && !allGone` block),
          replace the existing `StepPredictConflicts` call with:

          ```go
          // Step 1.3: PredictConflicts (E11 enhanced) — manifest-level, run once
          {
              repoOpts := firstRepoOpts(opts, repos)
              _, conflictData, stepErr := StepPredictConflictsEnhanced(ctx, repoOpts, manifest, onEvent)
              if stepErr != nil {
                  // Check if conflicts are auto-mergeable
                  if conflictData != nil && conflictData.AutoMergeable == conflictData.ConflictsDetected {
                      // All conflicts are append-only — attempt auto-merge
                      _, autoMergeResults, autoErr := StepAutoMergeAppendConflicts(ctx, repoOpts, conflictData.Conflicts, onEvent)
                      if autoErr != nil {
                          return result, fmt.Errorf("engine.FinalizeWave: %w", autoErr)
                      }
                      // Auto-merge succeeded — log results and continue
                      loggerFrom(opts.Logger).Info("E11 enhanced: auto-merge succeeded",
                          "files", len(autoMergeResults), "agents_merged", countMergedAgents(autoMergeResults))
                  } else {
                      // Manual merge required
                      return result, fmt.Errorf("engine.FinalizeWave: %w", stepErr)
                  }
              }
          }
          ```

          Add helper function at end of `finalize.go`:

          ```go
          func countMergedAgents(results []AutoMergeData) int {
              seen := make(map[string]bool)
              for _, r := range results {
                  for _, a := range r.Agents {
                      seen[a] = true
                  }
              }
              return len(seen)
          }
          ```

