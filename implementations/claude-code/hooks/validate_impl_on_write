#!/usr/bin/env bash
# PostToolUse hook: auto-validate IMPL docs after Write/Edit
# Reads tool input JSON from stdin, checks if file is an IMPL doc,
# runs sawtools validate, blocks on failure.
#
# Install: symlink to ~/.local/bin/validate_impl_on_write
# Config:  PostToolUse hook with matcher "Write|Edit" in ~/.claude/settings.json

set -euo pipefail

# Require jq for JSON parsing
if ! command -v jq &>/dev/null; then
  exit 0
fi

# Read the tool input JSON from stdin
INPUT=$(cat)

# Extract file_path from the JSON (tool_input.file_path)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)

# Only act on IMPL doc writes
if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

# Match active IMPL docs only (skip archived /complete/ docs)
case "$FILE_PATH" in
  */docs/IMPL/complete/*)
    exit 0
    ;;
  */docs/IMPL/IMPL-*.yaml|*/docs/IMPL/IMPL-*.yml)
    ;;
  *)
    exit 0
    ;;
esac

# Skip if file doesn't exist
if [[ ! -f "$FILE_PATH" ]]; then
  exit 0
fi

# Require sawtools for validation
if ! command -v sawtools &>/dev/null; then
  exit 0
fi

# Step 1: Structural validation (E16 schema/structural checks).
# Run without --fix: Scout's Step 16 handles auto-fix; hook only reports.
RESULT=$(sawtools validate "$FILE_PATH" 2>&1) || true
VALID=$(echo "$RESULT" | jq -r '.valid // empty' 2>/dev/null)

if [[ "$VALID" != "true" ]]; then
  ERROR_COUNT=$(echo "$RESULT" | jq -r '.error_count // 0' 2>/dev/null)
  ERRORS=$(echo "$RESULT" | jq -r '.errors[]?.message // empty' 2>/dev/null)
  echo "BLOCKED: IMPL structural validation failed ($ERROR_COUNT errors). Fix these before continuing:" >&2
  echo "$ERRORS" >&2
  exit 2
fi

# Step 2: Brief validation (symbol existence, line references, wave number consistency).
# Only run if validate-briefs is available (it ships with sawtools >= v0.93.0).
BRIEF_RESULT=$(sawtools validate-briefs "$FILE_PATH" 2>&1) || true
BRIEF_VALID=$(echo "$BRIEF_RESULT" | jq -r '.valid // empty' 2>/dev/null)

if [[ "$BRIEF_VALID" == "false" ]]; then
  echo "BLOCKED: IMPL brief validation failed. Fix these before continuing:" >&2
  # Print each error-severity issue as "Agent X: [check] description"
  echo "$BRIEF_RESULT" | jq -r '
    .agent_results | to_entries[] |
    .key as $agent |
    .value.issues[]? |
    select(.severity == "error") |
    "  Agent " + $agent + ": [" + .check + "] " + .description
  ' 2>/dev/null >&2 || \
    echo "$BRIEF_RESULT" | jq -r '.summary // "unknown brief validation error"' 2>/dev/null >&2
  exit 2
fi
