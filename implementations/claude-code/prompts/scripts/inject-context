#!/usr/bin/env bash
# inject-context -- orchestrator-level context injection for SAW skill
#
# Matches user prompt against orchestrator trigger patterns and outputs
# reference file contents. Called by inject_skill_context hook.
#
# Usage: scripts/inject-context "user prompt text"

set -euo pipefail

PROMPT="${1:-$(command cat)}"
[[ -z "$PROMPT" ]] && exit 0

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"

inject_file() {
  local file="$1"
  local ref_path="${SKILL_DIR}/${file}"
  [[ -f "$ref_path" ]] || { echo "warn: not found: ${ref_path}" >&2; return 0; }
  printf '<!-- injected: %s -->\n' "$file"
  command cat "$ref_path"
  printf '\n\n'
}

injected=""

if echo "$PROMPT" | grep -qE "^/saw program"; then
  injected+="$(inject_file "references/program-flow.md")"
fi

if echo "$PROMPT" | grep -qE "^/saw amend"; then
  injected+="$(inject_file "references/amend-flow.md")"
fi

if echo "$PROMPT" | grep -qE "^/saw auto"; then
  # /saw auto runs the full scout -> review -> wave flow inline.
  # The auto flow is defined in saw-skill.md core (Tier 2), not a reference file.
  # No injection needed; this block documents the pattern for maintainability.
  :
fi

[[ -n "$injected" ]] && printf '%s' "$injected"
